#!/usr/bin/env bash
# ovim-ctl - Control headless ovim instances

set -euo pipefail

# Use configurable session directory if provided, otherwise platform defaults
if [[ -n "${OVIM_SESSION_DIR:-}" ]]; then
    SESSIONS_DIR="$OVIM_SESSION_DIR"
elif [[ "$(uname)" == "Darwin" ]]; then
    SESSIONS_DIR="$HOME/Library/Caches/ovim/sessions"
else
    SESSIONS_DIR="$HOME/.cache/ovim/sessions"
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

error() {
    echo -e "${RED}Error: $1${NC}" >&2
    exit 1
}

info() {
    echo -e "${BLUE}$1${NC}"
}

success() {
    echo -e "${GREEN}$1${NC}"
}

read_health_ready() {
    local port="$1"
    local tmp_file
    tmp_file="$(mktemp "${TMPDIR:-/tmp}/ovim-health.XXXXXX")"

    if ! curl -s "http://127.0.0.1:$port/v1/health" > "$tmp_file" 2>/dev/null; then
        rm -f "$tmp_file"
        return 1
    fi

    local ready
    ready=$(jq -r '.ready' "$tmp_file" 2>/dev/null || echo "false")
    rm -f "$tmp_file"
    echo "$ready"
    return 0
}

# Get port for a session name
get_port() {
    local session_name="$1"
    local session_file="$SESSIONS_DIR/${session_name}.json"

    if [[ ! -f "$session_file" ]]; then
        error "Session '$session_name' not found"
    fi

    # Extract port from JSON
    local port=$(jq -r '.port' "$session_file" 2>/dev/null || echo "")

    if [[ -z "$port" ]]; then
        error "Failed to get port from session file"
    fi

    echo "$port"
}

# List all sessions
list_sessions() {
    if [[ ! -d "$SESSIONS_DIR" ]]; then
        echo "No sessions found"
        return
    fi

    local found=0
    for session_file in "$SESSIONS_DIR"/*.json; do
        if [[ ! -f "$session_file" ]]; then
            continue
        fi

        found=1
        local session_name=$(basename "$session_file" .json)
        local pid=$(jq -r '.pid' "$session_file" 2>/dev/null || echo "?")
        local port=$(jq -r '.port' "$session_file" 2>/dev/null || echo "?")
        local file=$(jq -r '.file // "no file"' "$session_file" 2>/dev/null || echo "?")
        local lsp_ready=$(jq -r '.lsp_ready' "$session_file" 2>/dev/null || echo "false")

        # Check if process is still alive
        if ! kill -0 "$pid" 2>/dev/null; then
            echo -e "${session_name} ${RED}(stale)${NC} pid: $pid, port: $port"
            continue
        fi

        # Get health status
        local ready_status="${RED}not ready${NC}"
        if ready=$(read_health_ready "$port"); then
            if [[ "$ready" == "true" ]]; then
                ready_status="${GREEN}ready${NC}"
            fi
        fi

        echo -e "${GREEN}${session_name}${NC} (pid: $pid, port: $port) $file [LSP: $ready_status]"
    done

    if [[ $found -eq 0 ]]; then
        echo "No sessions found"
    fi
}

# Send keys to a session
send_keys() {
    local session_name="$1"
    local keys="$2"
    local port=$(get_port "$session_name")

    curl -s -X POST "http://127.0.0.1:$port/v1/keys" \
        -H "Content-Type: application/json" \
        -d "{\"keys\": \"$keys\"}" | jq '.'
}

# Get health status
get_health() {
    local session_name="$1"
    local port=$(get_port "$session_name")

    curl -s "http://127.0.0.1:$port/v1/health" | jq '.'
}

# Get LSP status
get_lsp_status() {
    local session_name="$1"
    local port=$(get_port "$session_name")

    curl -s "http://127.0.0.1:$port/v1/lsp/status" | jq '.'
}

# Get snapshot
get_snapshot() {
    local session_name="$1"
    local port=$(get_port "$session_name")

    curl -s "http://127.0.0.1:$port/v1/snapshot" | jq '.'
}

# Kill a session
kill_session() {
    local session_name="$1"
    local session_file="$SESSIONS_DIR/${session_name}.json"

    if [[ ! -f "$session_file" ]]; then
        error "Session '$session_name' not found"
    fi

    local pid=$(jq -r '.pid' "$session_file" 2>/dev/null || echo "")

    if [[ -z "$pid" ]]; then
        error "Failed to get PID from session file"
    fi

    if kill "$pid" 2>/dev/null; then
        success "Session '$session_name' (PID: $pid) killed"
        sleep 1
        rm -f "$session_file" 2>/dev/null || true
    else
        info "Process $pid not running, cleaning up session file"
        rm -f "$session_file"
    fi
}

# Wait for LSP to be ready
wait_ready() {
    local session_name="$1"
    local timeout="${2:-60}"
    local port=$(get_port "$session_name")

    info "Waiting for LSP to be ready (timeout: ${timeout}s)..."

    local start=$(date +%s)
    while true; do
        local now=$(date +%s)
        local elapsed=$((now - start))

        if [[ $elapsed -ge $timeout ]]; then
            error "Timeout waiting for LSP to be ready"
        fi

        if ready=$(read_health_ready "$port"); then
            if [[ "$ready" == "true" ]]; then
                success "LSP is ready!"
                return 0
            fi
        fi

        sleep 0.5
    done
}

# Show usage
usage() {
    cat <<EOF
ovim-ctl - Control headless ovim instances

Usage:
  ovim-ctl list                        List all active sessions
  ovim-ctl send <session> <keys>       Send keys to a session
  ovim-ctl health <session>            Get health status
  ovim-ctl lsp <session>               Get LSP status
  ovim-ctl snapshot <session>          Get editor snapshot
  ovim-ctl kill <session>              Kill a session
  ovim-ctl wait <session> [timeout]    Wait for LSP to be ready
  ovim-ctl help                        Show this help

Examples:
  ovim-ctl list
  ovim-ctl send main "gg"
  ovim-ctl send main "iHello<Esc>"
  ovim-ctl health main
  ovim-ctl lsp main
  ovim-ctl kill main
  ovim-ctl wait main 30

Session names default to "default" if not specified when starting ovim.
Start a session with: ovim --headless --session <name> <file>
EOF
}

# Main command dispatcher
case "${1:-}" in
    list|ls)
        list_sessions
        ;;
    send|keys)
        if [[ $# -lt 3 ]]; then
            error "Usage: ovim-ctl send <session> <keys>"
        fi
        send_keys "$2" "$3"
        ;;
    health|h)
        if [[ $# -lt 2 ]]; then
            error "Usage: ovim-ctl health <session>"
        fi
        get_health "$2"
        ;;
    lsp)
        if [[ $# -lt 2 ]]; then
            error "Usage: ovim-ctl lsp <session>"
        fi
        get_lsp_status "$2"
        ;;
    snapshot|snap)
        if [[ $# -lt 2 ]]; then
            error "Usage: ovim-ctl snapshot <session>"
        fi
        get_snapshot "$2"
        ;;
    kill|stop)
        if [[ $# -lt 2 ]]; then
            error "Usage: ovim-ctl kill <session>"
        fi
        kill_session "$2"
        ;;
    wait|wait-ready)
        if [[ $# -lt 2 ]]; then
            error "Usage: ovim-ctl wait <session> [timeout]"
        fi
        wait_ready "$2" "${3:-60}"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
