{
  "description": "Working JSON-RPC messages for rust-analyzer LSP communication",
  "protocol_notes": [
    "All messages must be prefixed with 'Content-Length: {bytes}\\r\\n\\r\\n'",
    "Use CRLF (\\r\\n) line endings, not LF (\\n)",
    "Positions use UTF-16 code units (as per positionEncoding in capabilities)",
    "Wait 10-15 seconds after didOpen before sending hover requests"
  ],

  "1_initialize_request": {
    "description": "First message to start LSP session",
    "timing": "Response arrives in ~500ms",
    "message": {
      "jsonrpc": "2.0",
      "id": 1,
      "method": "initialize",
      "params": {
        "processId": null,
        "rootUri": "file:///workspace",
        "workspaceFolders": [{
          "uri": "file:///workspace",
          "name": "ovim"
        }],
        "capabilities": {
          "workspace": {
            "configuration": true,
            "workspaceFolders": true
          },
          "textDocument": {
            "hover": {
              "dynamicRegistration": false,
              "contentFormat": ["markdown", "plaintext"]
            },
            "synchronization": {
              "dynamicRegistration": false,
              "willSave": false,
              "didSave": true,
              "willSaveWaitUntil": false
            },
            "definition": {
              "dynamicRegistration": false,
              "linkSupport": false
            }
          }
        },
        "initializationOptions": {
          "checkOnSave": {
            "enable": false
          },
          "cargo": {
            "loadOutDirsFromCheck": true
          }
        }
      }
    },
    "response_summary": {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "capabilities": {
          "positionEncoding": "utf-16",
          "textDocumentSync": {
            "openClose": true,
            "change": 2,
            "save": {}
          },
          "hoverProvider": true,
          "definitionProvider": true,
          "note": "Many other capabilities returned (completionProvider, signatureHelpProvider, etc.)"
        },
        "serverInfo": {
          "name": "rust-analyzer",
          "version": "1.90.0 (1159e78 2025-09-14)"
        }
      }
    }
  },

  "2_initialized_notification": {
    "description": "Notification sent after receiving initialize response",
    "timing": "Send immediately after step 1 response, wait 1s before next",
    "no_response": true,
    "message": {
      "jsonrpc": "2.0",
      "method": "initialized",
      "params": {}
    }
  },

  "3_didOpen_notification": {
    "description": "Open a document for editing",
    "timing": "Wait 10-15 seconds after this before sending hover requests",
    "no_response": false,
    "server_sends_diagnostics": true,
    "message": {
      "jsonrpc": "2.0",
      "method": "textDocument/didOpen",
      "params": {
        "textDocument": {
          "uri": "file:///workspace/src/buffer/mod.rs",
          "languageId": "rust",
          "version": 1,
          "text": "<full file content here - must be complete file>"
        }
      }
    },
    "server_notification_received": {
      "description": "Server sends diagnostics notification asynchronously",
      "message": {
        "jsonrpc": "2.0",
        "method": "textDocument/publishDiagnostics",
        "params": {
          "uri": "file:///workspace/src/buffer/mod.rs",
          "diagnostics": [],
          "version": 1
        }
      }
    }
  },

  "4_hover_request": {
    "description": "Request hover information at a position",
    "timing": "Only send 10-15s after didOpen, response in ~100-500ms",
    "important": "Position uses UTF-16 code units, not UTF-8 bytes or chars",
    "message": {
      "jsonrpc": "2.0",
      "id": 2,
      "method": "textDocument/hover",
      "params": {
        "textDocument": {
          "uri": "file:///workspace/src/buffer/mod.rs"
        },
        "position": {
          "line": 57,
          "character": 15
        }
      }
    },
    "response_success": {
      "jsonrpc": "2.0",
      "id": 2,
      "result": {
        "contents": {
          "kind": "markdown",
          "value": "```rust\novim::buffer\n```\n\n```rust\npub struct Buffer {\n    rope: Rope,\n    cursor: Cursor,\n    modified: bool,\n    file_path: Option<String>,\n    syntax: Option<SyntaxHighlighter>,\n    /* … */\n}\n```\n\n---\n\nsize = 552 (0x228), align = 0x8, needs Drop\n\n---\n\nRepresents a text buffer using a Rope data structure for efficient editing"
        },
        "range": {
          "start": {"line": 57, "character": 11},
          "end": {"line": 57, "character": 17}
        }
      }
    },
    "response_null": {
      "description": "Returned when no hover info available or workspace not ready",
      "jsonrpc": "2.0",
      "id": 2,
      "result": null
    }
  },

  "5_didChange_notification": {
    "description": "Notify server of text changes (incremental sync)",
    "timing": "Send after user edits, debounce to avoid spam (150ms recommended)",
    "no_response": true,
    "message": {
      "jsonrpc": "2.0",
      "method": "textDocument/didChange",
      "params": {
        "textDocument": {
          "uri": "file:///workspace/src/buffer/mod.rs",
          "version": 2
        },
        "contentChanges": [
          {
            "range": {
              "start": {"line": 10, "character": 0},
              "end": {"line": 10, "character": 0}
            },
            "rangeLength": 0,
            "text": "// New comment\n"
          }
        ]
      }
    },
    "alternative_full_sync": {
      "description": "If using textDocumentSync.change = 1 (full sync)",
      "contentChanges": [
        {
          "text": "<entire new file content>"
        }
      ]
    }
  },

  "6_gotoDefinition_request": {
    "description": "Request definition location for symbol at position",
    "timing": "Same as hover - wait 10-15s after didOpen",
    "message": {
      "jsonrpc": "2.0",
      "id": 3,
      "method": "textDocument/definition",
      "params": {
        "textDocument": {
          "uri": "file:///workspace/src/buffer/mod.rs"
        },
        "position": {
          "line": 57,
          "character": 15
        }
      }
    },
    "response_example": {
      "jsonrpc": "2.0",
      "id": 3,
      "result": {
        "uri": "file:///workspace/src/buffer/mod.rs",
        "range": {
          "start": {"line": 57, "character": 11},
          "end": {"line": 57, "character": 17}
        }
      }
    }
  },

  "7_shutdown_request": {
    "description": "Shutdown LSP server gracefully",
    "timing": "Response immediate",
    "important": "params must be null, not {}",
    "message": {
      "jsonrpc": "2.0",
      "id": 99,
      "method": "shutdown",
      "params": null
    },
    "response": {
      "jsonrpc": "2.0",
      "id": 99,
      "result": null
    }
  },

  "8_exit_notification": {
    "description": "Exit LSP server process",
    "timing": "Send after shutdown response",
    "no_response": true,
    "server_exits": true,
    "message": {
      "jsonrpc": "2.0",
      "method": "exit"
    }
  },

  "common_errors": {
    "malformed_header": {
      "error": "Error: malformed header: \"Content-Length: 251\\n\"",
      "cause": "Using \\n instead of \\r\\n for line endings",
      "fix": "Use printf with \\r\\n: printf 'Content-Length: %d\\r\\n\\r\\n%s' \"$length\" \"$message\""
    },
    "shutdown_params_error": {
      "error": "Failed to deserialize shutdown: invalid type: map, expected unit; {}",
      "cause": "Using {} instead of null for shutdown params",
      "fix": "Use params: null"
    },
    "hover_returns_null": {
      "causes": [
        "Workspace not indexed yet (most common - wait longer)",
        "Position outside valid range",
        "No symbol at position",
        "File not in workspace (check Cargo.toml)"
      ]
    },
    "position_column_exceeds_line_length": {
      "warning": "Position LineCol { line: 8, col: 18 } column exceeds line length 17, clamping it",
      "cause": "Column position beyond line end",
      "behavior": "rust-analyzer clamps position to line length"
    }
  },

  "timing_summary": {
    "initialization_sequence": "~2-3 seconds total",
    "workspace_indexing": "10-15 seconds after didOpen",
    "hover_response": "100-500ms after workspace ready",
    "debounce_didChange": "150ms recommended to avoid spam"
  },

  "position_encoding_examples": {
    "note": "rust-analyzer uses UTF-16 code units",
    "ascii_line": {
      "text": "let x = 5;",
      "position_of_x": {
        "byte_offset": 4,
        "char_offset": 4,
        "utf16_offset": 4,
        "lsp_position": {"line": 0, "character": 4}
      }
    },
    "emoji_line": {
      "text": "let 😀 = 5;",
      "position_of_equals": {
        "byte_offset": 8,
        "char_offset": 5,
        "utf16_offset": 6,
        "lsp_position": {"line": 0, "character": 6},
        "note": "Emoji takes 2 UTF-16 code units"
      }
    }
  }
}
