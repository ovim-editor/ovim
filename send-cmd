#!/usr/bin/env zsh

# TODO: This is deprecated and should be removed in favor of ovim-ctl.
#       It is used in some ad-hoc tests that must be updated first.

# send-cmd - Thin curl wrapper for ovim REST API
# Usage:
#   ./send-cmd <port> keys "gg"
#   ./send-cmd <port> buffer "Hello World"
#   ./send-cmd <port> get buffer
#   ./send-cmd <port> get cursor
#   ./send-cmd <port> command "w"

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

if [ $# -lt 2 ]; then
    echo -e "${RED}Usage:${NC}"
    echo "  $0 <port> keys <keys>"
    echo "  $0 <port> buffer <content>"
    echo "  $0 <port> get <endpoint>"
    echo "  $0 <port> command <cmd>"
    echo ""
    echo -e "${BLUE}Examples:${NC}"
    echo "  $0 56789 keys \"gg\""
    echo "  $0 56789 keys \"iHello<Esc>\""
    echo "  $0 56789 buffer \"Line 1\\nLine 2\""
    echo "  $0 56789 get buffer"
    echo "  $0 56789 get cursor"
    echo "  $0 56789 get mode"
    echo "  $0 56789 get snapshot"
    echo "  $0 56789 command \"w\""
    exit 1
fi

PORT=$1
API_URL="http://127.0.0.1:$PORT"
shift

COMMAND=$1
shift

case "$COMMAND" in
    keys)
        if [ $# -lt 1 ]; then
            echo -e "${RED}Error: keys command requires data${NC}"
            exit 1
        fi
        KEYS="$1"
        echo -e "${BLUE}Sending keys: ${YELLOW}$KEYS${NC}"
        curl -s -X POST "$API_URL/keys" \
            -H "Content-Type: application/json" \
            -d "{\"keys\": \"$KEYS\"}" | jq '.' 2>/dev/null || cat
        ;;

    buffer)
        if [ $# -lt 1 ]; then
            echo -e "${RED}Error: buffer command requires content${NC}"
            exit 1
        fi
        CONTENT="$1"
        echo -e "${BLUE}Setting buffer content${NC}"
        # Escape the content for JSON
        ESCAPED=$(echo "$CONTENT" | jq -Rs .)
        curl -s -X PUT "$API_URL/buffer" \
            -H "Content-Type: application/json" \
            -d "{\"content\": $ESCAPED}" | jq '.' 2>/dev/null || cat
        ;;

    get)
        if [ $# -lt 1 ]; then
            echo -e "${RED}Error: get command requires endpoint${NC}"
            exit 1
        fi
        ENDPOINT="$1"
        echo -e "${BLUE}GET /$ENDPOINT${NC}"
        curl -s "$API_URL/$ENDPOINT" | jq '.' 2>/dev/null || cat
        ;;

    command)
        if [ $# -lt 1 ]; then
            echo -e "${RED}Error: command requires cmd string${NC}"
            exit 1
        fi
        CMD="$1"
        echo -e "${BLUE}Executing command: ${YELLOW}:$CMD${NC}"
        curl -s -X POST "$API_URL/command" \
            -H "Content-Type: application/json" \
            -d "{\"command\": \"$CMD\"}" | jq '.' 2>/dev/null || cat
        ;;

    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}"
        echo "Valid commands: keys, buffer, get, command"
        exit 1
        ;;
esac

echo ""
